{
  "name": "@guildora/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types/roles": {
      "types": "./src/types/roles.ts",
      "import": "./src/types/roles.ts",
      "default": "./src/types/roles.ts"
    },
    "./db/client": {
      "types": "./src/db/client.ts",
      "import": "./src/db/client.ts",
      "default": "./src/db/client.ts"
    },
    "./utils/application-tokens": {
      "types": "./src/utils/application-tokens.ts",
      "import": "./src/utils/application-tokens.ts",
      "default": "./src/utils/application-tokens.ts"
    },
    "./db/run-migrations": {
      "types": "./src/db/run-migrations.ts",
      "import": "./src/db/run-migrations.ts",
      "default": "./src/db/run-migrations.ts"
    },
    "./db/seeds/landing-templates": {
      "types": "./src/db/seeds/landing-templates.ts",
      "import": "./src/db/seeds/landing-templates.ts",
      "default": "./src/db/seeds/landing-templates.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No lint configured for @guildora/shared\"",
    "format": "echo \"No format script configured for @guildora/shared\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "node scripts/run-drizzle-generate.mjs",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "dotenv": "^16.4.7",
    "postgres": "^3.4.7",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^2.1.0"
  }
}
