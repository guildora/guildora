# =============================================================================
#  Guildora — Environment Configuration
# =============================================================================
#  Copy this file to .env and fill in the values.
#  Lines starting with # are comments. Commented-out vars are optional.
# =============================================================================


# ─── Core ────────────────────────────────────────────────────────────────────

NODE_ENV=production
APP_NAME=Guildora

# Hostnames used by Caddy / reverse proxy
APP_HOST=community.example.com
HUB_HOST=hub.community.example.com
CMS_HOST=cms.community.example.com
CADDY_NETWORK=caddy


# ─── Public URLs ─────────────────────────────────────────────────────────────
# Local dev defaults: Web=3000, Hub=3003, CMS=3002

NUXT_PUBLIC_APP_URL=https://community.example.com
NUXT_PUBLIC_HUB_URL=https://hub.community.example.com
NUXT_PUBLIC_CMS_URL=https://cms.community.example.com
PAYLOAD_PUBLIC_SERVER_URL=https://cms.community.example.com


# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (pnpm dev): points to docker-compose db on port 5433.
# Production (docker compose up): DATABASE_URL is set per service in
# docker-compose.yml — this value is ignored by containers.

DATABASE_URL=postgresql://postgres:postgres@localhost:5433/guildora

# Set to true only when connecting to external/cloud Postgres with TLS.
DATABASE_SSL=false


# ─── Auth & Sessions ────────────────────────────────────────────────────────

# Encrypts session cookies (nuxt-auth-utils). Use a strong random string (32+ chars).
NUXT_SESSION_PASSWORD=replace_with_very_strong_random_value

# Discord OAuth application credentials (hub login)
NUXT_OAUTH_DISCORD_CLIENT_ID=replace_with_discord_oauth_client_id
NUXT_OAUTH_DISCORD_CLIENT_SECRET=replace_with_discord_oauth_client_secret

# Must point to the Hub URL. Local dev: http://localhost:3003/api/auth/discord
NUXT_OAUTH_DISCORD_REDIRECT_URI=https://hub.community.example.com/api/auth/discord

# Discord user ID of the initial superadmin
SUPERADMIN_DISCORD_ID=replace_with_initial_superadmin_discord_id

# Development only: enables local superadmin OAuth bypass on /api/auth/discord
NUXT_AUTH_DEV_BYPASS=false


# ─── Secrets & Tokens ───────────────────────────────────────────────────────

# Shared secret for signing application tokens (hub + bot)
APPLICATION_TOKEN_SECRET=replace_with_strong_random_secret

# Payload CMS internal crypto & token signing
PAYLOAD_SECRET=replace_with_very_strong_random_value

# Shared secret for Hub → CMS SSO token signing
CMS_SSO_SECRET=replace_with_very_strong_random_value


# ─── Bot Sync Bridge (Hub ↔ Bot, internal network) ──────────────────────────

BOT_INTERNAL_URL=http://bot:3050
BOT_INTERNAL_TOKEN=replace_with_internal_sync_token


# ─── Payload CMS ────────────────────────────────────────────────────────────

# Optional: initial admin credentials (for seeding/first-run setup)
# PAYLOAD_ADMIN_EMAIL=admin@example.com
# PAYLOAD_ADMIN_PASSWORD=replace_with_strong_password

# Internal CMS URL for backend-to-backend calls (defaults to http://cms:3002)
# PAYLOAD_INTERNAL_URL=http://cms:3002

# Media storage path inside container
# MEDIA_STORAGE_PATH=/app/media


# ─── Media Storage (S3-compatible, optional) ─────────────────────────────────
# Leave commented out for local filesystem storage.
# Supported providers: s3 (AWS), r2 (Cloudflare), minio (self-hosted)

# BUCKET_PROVIDER=s3
# BUCKET_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# BUCKET_REGION=eu-central-1
# BUCKET_NAME=guildora-media
# BUCKET_ACCESS_KEY_ID=
# BUCKET_SECRET_ACCESS_KEY=
# BUCKET_PUBLIC_URL=https://media.example.com
# BUCKET_PATH_PREFIX=prod/


# ─── Discord Bot ─────────────────────────────────────────────────────────────

DISCORD_BOT_TOKEN=replace_with_discord_bot_token
DISCORD_CLIENT_ID=replace_with_discord_application_client_id
DISCORD_GUILD_ID=replace_with_discord_guild_id
BOT_INTERNAL_PORT=3050

# Optional: AFK voice channel ID (bot skips this channel)
# AFK_VOICE_CHANNEL_ID=


# ─── Frontend Theme ─────────────────────────────────────────────────────────

NUXT_PUBLIC_DEFAULT_THEME=retrofuturism
# NUXT_PUBLIC_ENABLE_PERFORMANCE_DEBUG=false


# ─── Integrations (optional) ────────────────────────────────────────────────

# Enable app sideloading (development feature)
# NUXT_ENABLE_SIDELOADING=false
