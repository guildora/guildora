{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "2.2",
  "description": "Summary of the shared application-domain schema from packages/shared/src/db/schema.ts. The public schema is primarily used by hub and bot; CMS-owned tables live separately in payload.",
  "entities": [
    {
      "id": "users",
      "table": "users",
      "fields": ["id", "discordId", "email", "displayName", "avatarUrl", "avatarSource", "primaryDiscordRoleName", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "notes": ["displayName is the serialized profile name string", "avatarSource tracks where the avatar was set from", "primaryDiscordRoleName is a snapshot of the user's primary Discord role"],
      "relations": ["profile", "permissionRoles", "communityRole", "discordRoles", "voiceSessions", "profileChangeLogs", "createdApps", "submittedAppSubmissions", "reviewedAppSubmissions", "createdApplicationFlows", "reviewedApplications", "applicationModeratorNotifications", "createdCommunityTags"]
    },
    {
      "id": "profiles",
      "table": "profiles",
      "fields": ["id", "userId", "absenceStatus", "absenceMessage", "absenceUntil", "customFields", "localePreference", "updatedAt"],
      "primaryKey": "id",
      "enums": { "absenceStatus": ["away", "maintenance"] },
      "notes": ["No bio field exists in the current schema", "customFields stores appearance and application metadata"],
      "customFieldsKnown": ["applicationStatus", "applicationReviewedAt", "applicationReviewedBy", "appearancePreference", "localePreference (legacy fallback)"]
    },
    {
      "id": "permission_roles",
      "table": "permission_roles",
      "fields": ["id", "name", "description", "level"],
      "primaryKey": "id",
      "names": ["temporaer", "user", "moderator", "admin", "superadmin"]
    },
    {
      "id": "community_roles",
      "table": "community_roles",
      "fields": ["id", "name", "description", "discordRoleId", "permissionRoleId", "sortOrder", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "notes": ["Maps one community role to one permission role", "discordRoleId is optional but unique when set"]
    },
    {
      "id": "user_permission_roles",
      "table": "user_permission_roles",
      "fields": ["userId", "permissionRoleId", "assignedAt"],
      "primaryKey": ["userId", "permissionRoleId"]
    },
    {
      "id": "user_community_roles",
      "table": "user_community_roles",
      "fields": ["userId", "communityRoleId", "assignedAt"],
      "primaryKey": "userId",
      "notes": ["At most one community role per user"]
    },
    {
      "id": "selectable_discord_roles",
      "table": "selectable_discord_roles",
      "fields": ["discordRoleId", "roleNameSnapshot", "createdAt", "updatedAt"],
      "primaryKey": "discordRoleId",
      "notes": ["Global admin-managed allowlist for self-service Discord roles"]
    },
    {
      "id": "user_discord_roles",
      "table": "user_discord_roles",
      "fields": ["userId", "discordRoleId", "roleNameSnapshot", "syncedAt"],
      "primaryKey": ["userId", "discordRoleId"],
      "notes": ["Snapshot table, not the live source of truth for Discord guild state"]
    },
    {
      "id": "voice_sessions",
      "table": "voice_sessions",
      "fields": ["id", "userId", "channelId", "startedAt", "endedAt", "durationMinutes", "createdAt"],
      "primaryKey": "id",
      "notes": ["One open session per user is enforced by a partial unique index"]
    },
    {
      "id": "profile_change_log",
      "table": "profile_change_log",
      "fields": ["id", "profileId", "changeType", "previousValue", "newValue", "isGrowth", "isDeparture", "changedBy", "createdAt"],
      "primaryKey": "id"
    },
    {
      "id": "installed_apps",
      "table": "installed_apps",
      "fields": ["id", "appId", "name", "version", "status", "source", "verified", "autoUpdate", "repositoryUrl", "manifest", "config", "codeBundle", "createdBy", "installedAt", "updatedAt"],
      "primaryKey": "id",
      "enums": { "status": ["active", "inactive", "error"], "source": ["marketplace", "sideloaded"] },
      "notes": ["codeBundle stores transpiled CJS code bundles as filePath to CJS source string mapping"]
    },
    {
      "id": "app_kv",
      "table": "app_kv",
      "fields": ["appId", "key", "value"],
      "primaryKey": ["appId", "key"],
      "notes": ["Key-value store scoped per installed app"]
    },
    {
      "id": "app_marketplace_submissions",
      "table": "app_marketplace_submissions",
      "fields": ["id", "appId", "name", "version", "sourceUrl", "manifest", "status", "automatedChecks", "reviewNotes", "submittedByUserId", "reviewedByUserId", "reviewedAt", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "enums": { "status": ["pending", "approved", "rejected"] },
      "notes": ["Retained schema for marketplace submissions; active local product flow is limited"]
    },
    {
      "id": "theme_settings",
      "table": "theme_settings",
      "fields": ["id", "colorDominant", "colorSecondary", "colorAccent", "colorAccentContentTone", "colorInfo", "colorInfoContentTone", "colorSuccess", "colorSuccessContentTone", "colorWarning", "colorWarningContentTone", "colorError", "colorErrorContentTone", "logoDataUrl", "logoMimeType", "logoFileName", "sidebarLogoSizePx", "updatedAt", "updatedBy"],
      "primaryKey": "id",
      "notes": ["Used as a singleton-like settings table by the hub app"]
    },
    {
      "id": "cms_access_settings",
      "table": "cms_access_settings",
      "fields": ["id", "allowModeratorAccess", "allowModeratorAppsAccess", "modDeleteUsers", "modManageApplications", "modAccessCommunitySettings", "modAccessDesign", "modAccessApps", "modAccessDiscordRoles", "modAccessCustomFields", "modAccessPermissions", "updatedAt", "updatedBy"],
      "primaryKey": "id",
      "notes": ["Controls both CMS access and granular moderator permissions for settings sections", "Despite the table name, this now serves as the central moderation-rights configuration"]
    },
    {
      "id": "community_settings",
      "table": "community_settings",
      "fields": ["id", "communityName", "discordInviteCode", "defaultLocale", "displayNameTemplate", "updatedAt", "updatedBy"],
      "primaryKey": "id",
      "notes": ["Current code treats id=1 as the singleton row", "displayNameTemplate is jsonb array of DisplayNameField objects defining community-wide name structure"]
    },
    {
      "id": "application_flows",
      "table": "application_flows",
      "fields": ["id", "name", "status", "flowJson", "settingsJson", "createdBy", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "enums": { "status": ["draft", "active", "inactive"] },
      "notes": ["Visual node-based application flow definitions", "flowJson stores the ApplicationFlowGraph with nodes and edges", "settingsJson stores ApplicationFlowSettings"]
    },
    {
      "id": "application_flow_embeds",
      "table": "application_flow_embeds",
      "fields": ["id", "flowId", "discordChannelId", "discordMessageId", "active", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "notes": ["Discord channel embeds that link to application flows"]
    },
    {
      "id": "application_tokens",
      "table": "application_tokens",
      "fields": ["id", "flowId", "discordId", "discordUsername", "discordAvatarUrl", "token", "expiresAt", "usedAt", "createdAt"],
      "primaryKey": "id",
      "notes": ["One-time-use tokens granting access to public application forms", "token is unique and has an expiry"]
    },
    {
      "id": "applications",
      "table": "applications",
      "fields": ["id", "flowId", "discordId", "discordUsername", "discordAvatarUrl", "answersJson", "status", "rolesAssigned", "pendingRoleAssignments", "displayNameComposed", "reviewedBy", "reviewedAt", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "enums": { "status": ["pending", "approved", "rejected"] },
      "notes": ["Submitted applications linked to a flow", "answersJson stores the applicant's responses", "rolesAssigned and pendingRoleAssignments track Discord role assignment state"]
    },
    {
      "id": "application_file_uploads",
      "table": "application_file_uploads",
      "fields": ["id", "applicationId", "discordId", "flowId", "originalFilename", "mimeType", "storagePath", "fileSize", "createdAt"],
      "primaryKey": "id",
      "notes": ["File attachments uploaded during the application process"]
    },
    {
      "id": "application_moderator_notifications",
      "table": "application_moderator_notifications",
      "fields": ["flowId", "userId", "enabled"],
      "primaryKey": ["flowId", "userId"],
      "notes": ["Per-flow notification preferences for moderators"]
    },
    {
      "id": "community_custom_fields",
      "table": "community_custom_fields",
      "fields": ["id", "key", "label", "description", "inputType", "options", "sliderMin", "sliderMax", "sliderStep", "required", "active", "isDefault", "userCanView", "userCanEdit", "modCanView", "modCanEdit", "sortOrder", "createdAt", "updatedAt"],
      "primaryKey": "id",
      "notes": ["Admin-managed custom profile fields distinct from profiles.customFields", "Supports input types with configurable visibility and edit permissions per role level", "options is a jsonb array for select/multi-select types", "sliderMin/sliderMax/sliderStep for slider input type"]
    },
    {
      "id": "community_tags",
      "table": "community_tags",
      "fields": ["id", "name", "createdAt", "createdBy"],
      "primaryKey": "id",
      "notes": ["Moderator-managed tags for categorizing or labeling users"]
    },
    {
      "id": "application_access_settings",
      "table": "application_access_settings",
      "fields": ["id", "allowModeratorAccess", "updatedAt", "updatedBy"],
      "primaryKey": "id",
      "notes": ["Singleton controlling whether moderators can access the application management section"]
    }
  ]
}
