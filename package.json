{
  "name": "guildora",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "predev": "node scripts/check-ports.js",
    "dev": "turbo run dev --parallel --continue",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @guildora/shared db:generate",
    "db:migrate": "pnpm --filter @guildora/shared db:migrate",
    "db:seed": "pnpm --filter @guildora/shared db:seed",
    "bot:deploy-commands": "pnpm --filter @guildora/bot deploy:commands"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
