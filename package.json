{
  "name": "guildora",
  "version": "0.1.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "packageManager": "pnpm@10.6.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel --continue",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "db:generate": "pnpm --filter @guildora/shared db:generate",
    "db:migrate": "pnpm --filter @guildora/shared db:migrate",
    "db:seed": "pnpm --filter @guildora/shared db:seed",
    "bot:deploy-commands": "pnpm --filter @guildora/bot deploy:commands",
    "test": "turbo run test",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:integration": "turbo run test:integration",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage",
    "preview": "turbo run build && turbo run start --parallel --continue"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.2",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "devalue": ">=5.6.4",
      "undici": ">=6.24.0 <8.0.0",
      "flatted": ">=3.4.2",
      "node-forge": ">=1.3.4",
      "picomatch": ">=4.0.4",
      "happy-dom": ">=20.8.9",
      "h3": ">=1.15.9",
      "srvx": ">=0.11.13",
      "postcss": ">=8.4.31",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "yaml": ">=2.8.3",
      "ajv": ">=8.18.0"
    }
  }
}
