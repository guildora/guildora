{
  "name": "@guildora/bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo \"No lint configured for @guildora/bot\"",
    "format": "echo \"No format script configured for @guildora/bot\"",
    "deploy:commands": "tsx src/utils/deploy-commands.ts"
  },
  "dependencies": {
    "@guildora/app-sdk": "workspace:*",
    "@guildora/shared": "workspace:*",
    "discord.js": "^14.25.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.5",
    "esbuild": "^0.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
