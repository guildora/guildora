{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["node"],
    "paths": {
      "@guildora/app-sdk": ["../../packages/app-sdk/src/index.ts"],
      "@guildora/app-sdk/*": ["../../packages/app-sdk/src/*"],
      "@guildora/shared": ["../../packages/shared/src/index.ts"],
      "@guildora/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
